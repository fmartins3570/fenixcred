# Apache Configuration - Cache Agressivo de Assets Estáticos
# Site: fenixcredbr.com.br
# Objetivo: Reduzir crawl budget desperdiçado (71% em recursos)
# Colocar este arquivo na raiz do diretório público (onde está o index.html)

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Redirecionar HTTP para HTTPS
    RewriteCond %{HTTPS} off
    RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # Servir arquivos da pasta dist/ (deploy via Git)
    # Se não é um arquivo/pasta existente na raiz, buscar em dist/
    RewriteCond %{REQUEST_URI} !^/dist/
    RewriteCond %{DOCUMENT_ROOT}/dist%{REQUEST_URI} -f [OR]
    RewriteCond %{DOCUMENT_ROOT}/dist%{REQUEST_URI} -d
    RewriteRule ^(.*)$ /dist/$1 [L]

    # Redirecionar www para não-www (ou vice-versa, ajustar conforme preferência)
    # RewriteCond %{HTTP_HOST} ^www\.(.*)$ [NC]
    # RewriteRule ^(.*)$ https://%1/$1 [R=301,L]
</IfModule>

# ============================================
# CACHE AGRESSIVO PARA ASSETS ESTÁTICOS
# ============================================

<IfModule mod_expires.c>
    ExpiresActive On
    
    # JavaScript - Cache de 1 ano (31536000 segundos)
    ExpiresByType application/javascript "access plus 1 year"
    ExpiresByType text/javascript "access plus 1 year"
    ExpiresByType application/x-javascript "access plus 1 year"
    
    # CSS - Cache de 1 ano
    ExpiresByType text/css "access plus 1 year"
    
    # Imagens - Cache de 1 ano
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/x-icon "access plus 1 year"
    ExpiresByType image/vnd.microsoft.icon "access plus 1 year"
    ExpiresByType image/ico "access plus 1 year"
    
    # Fontes - Cache de 1 ano
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType application/font-woff "access plus 1 year"
    ExpiresByType application/font-woff2 "access plus 1 year"
    ExpiresByType font/ttf "access plus 1 year"
    ExpiresByType font/opentype "access plus 1 year"
    ExpiresByType application/x-font-ttf "access plus 1 year"
    ExpiresByType application/x-font-opentype "access plus 1 year"
    ExpiresByType font/eot "access plus 1 year"
    ExpiresByType application/vnd.ms-fontobject "access plus 1 year"
    
    # HTML - Cache curto (1 hora) para permitir atualizações
    ExpiresByType text/html "access plus 1 hour"
    
    # Arquivos de configuração - Cache médio (1 dia)
    ExpiresByType text/plain "access plus 1 day"
    ExpiresByType application/xml "access plus 1 day"
    ExpiresByType text/xml "access plus 1 day"
</IfModule>

# ============================================
# CACHE-CONTROL HEADERS COM IMMUTABLE
# ============================================

<IfModule mod_headers.c>
    # JavaScript - Cache agressivo com immutable
    <FilesMatch "\.(js)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
        Header set X-Content-Type-Options "nosniff"
        Header unset ETag
    </FilesMatch>
    
    # CSS - Cache agressivo com immutable
    <FilesMatch "\.(css)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
        Header set X-Content-Type-Options "nosniff"
        Header unset ETag
    </FilesMatch>
    
    # Imagens - Cache agressivo com immutable
    <FilesMatch "\.(jpg|jpeg|png|gif|svg|webp|ico)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
        Header set X-Content-Type-Options "nosniff"
        Header unset ETag
    </FilesMatch>
    
    # Fontes - Cache agressivo com immutable e CORS
    <FilesMatch "\.(woff|woff2|ttf|eot|otf)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
        Header set Access-Control-Allow-Origin "*"
        Header set X-Content-Type-Options "nosniff"
        Header unset ETag
    </FilesMatch>
    
    # HTML - Cache curto
    <FilesMatch "\.(html|htm)$">
        Header set Cache-Control "public, max-age=3600, must-revalidate"
        Header unset ETag
    </FilesMatch>
    
    # Arquivos de configuração - Cache médio
    <FilesMatch "\.(txt|xml)$">
        Header set Cache-Control "public, max-age=86400"
        Header unset ETag
    </FilesMatch>
    
    # Security headers globais
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    
    # CSP - Content Security Policy (segurança XSS)
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://www.googletagmanager.com https://www.google-analytics.com https://maps.googleapis.com https://maps.gstatic.com https://connect.facebook.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: https: blob:; font-src 'self' https://fonts.gstatic.com data:; connect-src 'self' https://www.google-analytics.com https://maps.googleapis.com https://www.facebook.com https://script.google.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; object-src 'none'; upgrade-insecure-requests;"
    
    # HSTS - HTTP Strict Transport Security (força HTTPS)
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    
    # COOP - Cross-Origin-Opener-Policy (isolamento de origem)
    Header always set Cross-Origin-Opener-Policy "same-origin"
    
    # COEP - Cross-Origin-Embedder-Policy
    Header always set Cross-Origin-Embedder-Policy "require-corp"
    
    # CORP - Cross-Origin-Resource-Policy
    Header always set Cross-Origin-Resource-Policy "same-origin"
</IfModule>

# ============================================
# DESABILITAR LOGS PARA ASSETS ESTÁTICOS
# ============================================

# Desabilitar logging para assets estáticos (economia de I/O)
SetEnvIf Request_URI "\.(js|css|jpg|jpeg|png|gif|svg|webp|ico|woff|woff2|ttf|eot)$" dontlog
CustomLog /dev/null combined env=dontlog

# ============================================
# COMPRESSÃO GZIP
# ============================================

<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE text/javascript
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/json
    AddOutputFilterByType DEFLATE application/xml
    AddOutputFilterByType DEFLATE text/xml
    AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# ============================================
# SPA ROUTING - React Router
# ============================================

<IfModule mod_rewrite.c>
    # Redirecionar rotas do SPA diretamente para o index.html
    RewriteRule ^page-credito-clt-personalizado/?$ /dist/index.html [L]
    RewriteRule ^page-credito-clt/?$ /dist/index.html [L]
    RewriteRule ^politica-privacidade/?$ /dist/index.html [L]
    RewriteRule ^exclusao-de-dados/?$ /dist/index.html [L]

    # Redirecionar todas as rotas para index.html (exceto arquivos existentes)
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule . /dist/index.html [L]
</IfModule>

# ============================================
# SEGURANÇA - BLOQUEAR ARQUIVOS SENSÍVEIS
# ============================================

# Bloquear acesso a arquivos ocultos
<FilesMatch "^\.">
    Order allow,deny
    Deny from all
</FilesMatch>

# Bloquear acesso a arquivos de configuração
<FilesMatch "\.(env|git|svn|htaccess|htpasswd|ini|log|sh|sql|conf)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# ============================================
# REMOVER ETAGS (usar apenas Cache-Control)
# ============================================

<IfModule mod_headers.c>
    Header unset ETag
</IfModule>
FileETag None
